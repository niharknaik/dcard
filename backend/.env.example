APP_NAME=DCard
# Use APP_ENV=production in production (enables HTTPS URL scheme + HSTS).
APP_ENV=local
APP_KEY=
# IMPORTANT: APP_DEBUG must be false in production to avoid leaking stack traces.
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000
APP_FRONTEND_URL=http://localhost:3000

# ---------- CORS ----------
# Comma-separated list of allowed origins (consumed by config/cors.php).
# Defaults to "*" when empty; set explicit origins in production, e.g.
# CORS_ALLOWED_ORIGINS=https://app.dcard.app,https://dcard.app
CORS_ALLOWED_ORIGINS=

# Public card base URL (used for slugs & QR codes) -> https://domain.com/card/{slug}
CARD_PUBLIC_BASE_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ---------- Database ----------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=dcard
DB_USERNAME=root
DB_PASSWORD=

# ---------- Cache / Queue / Session ----------
CACHE_STORE=database
QUEUE_CONNECTION=database
SESSION_DRIVER=database
SESSION_LIFETIME=120

# ---------- JWT ----------
JWT_SECRET=
JWT_TTL=60
JWT_REFRESH_TTL=20160

# ---------- Mail (use any SMTP provider; no paid push services) ----------
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@dcard.app"
MAIL_FROM_NAME="${APP_NAME}"

# ---------- Filesystem (local dev -> R2 ready) ----------
FILESYSTEM_DISK=local
# Cloudflare R2 (S3-compatible) — fill in for production
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=
R2_URL=

# ---------- Razorpay ----------
RAZORPAY_KEY=
RAZORPAY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ---------- Google Play Billing (Android server-side verification) ----------
# Android app package name as registered in the Play Console.
GOOGLE_PLAY_PACKAGE_NAME=
# Provide EITHER the absolute path to the service-account JSON key file...
GOOGLE_PLAY_SERVICE_ACCOUNT_PATH=
# ...OR paste the raw service-account JSON (single line). One of the two is required.
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=

# ---------- Rate limiting ----------
API_RATE_LIMIT=60
AUTH_RATE_LIMIT=10

# ---------- Seeded admin accounts (change before production) ----------
ADMIN_EMAIL=admin@dcard.app
ADMIN_PASSWORD=Admin@12345
SUPERADMIN_EMAIL=superadmin@dcard.app
SUPERADMIN_PASSWORD=Super@12345
