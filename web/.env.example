# Base URL of the DCard backend API.
# API_URL is read server-side (SSR public card viewer).
# NEXT_PUBLIC_API_URL is inlined into the browser bundle (dashboard / login).
# Both default to http://localhost:8000/api/v1 when unset.
API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
